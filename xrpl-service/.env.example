# XRPL WebSocket endpoint (defaults to testnet)
XRPL_WSS_URL=wss://s.altnet.rippletest.net:51233

# Merchant XRPL account (receives payments)
XRPL_MERCHANT_ADDRESS=
XRPL_MERCHANT_SEED=

# Customer XRPL account (testnet demo only — never store real seeds)
XRPL_CUSTOMER_ADDRESS=
XRPL_CUSTOMER_SEED=

# Exchange rate: USD per 1 XRP (update regularly in production)
XRPL_XRP_USD_RATE=2.50
