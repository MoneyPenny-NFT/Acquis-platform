{
  "name": "@acquis/card-sdk",
  "version": "0.1.0",
  "private": true,
  "description": "Embeddable Acquis BaaS SDK for browser and Node.js",
  "type": "module",
  "main": "dist/card-sdk.umd.cjs",
  "module": "dist/card-sdk.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/card-sdk.js",
      "require": "./dist/card-sdk.umd.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "vite build && tsc --emitDeclarationOnly",
    "dev": "vite build --watch",
    "test": "jest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.3.0",
    "vite": "^5.4.0",
    "vite-plugin-dts": "^3.9.0"
  }
}
