# Safe defaults — committed
VITE_API_BASE_URL=

# Secrets — copy to .env.local (gitignored, never committed)
VITE_API_KEY=your_api_key_here

# Admin mode — exposes Hedera ops (Accounts, Tokens, Transfers) for Acquis internal use.
# Never set to true in merchant-facing deployments.
VITE_ADMIN_MODE=false
