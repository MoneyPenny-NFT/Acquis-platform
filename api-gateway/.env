PORT=3000
HEDERA_NETWORK=testnet
DATABASE_URL=file:/tmp/acquis.db
REDIS_HOST=localhost
REDIS_PORT=6379

# Bank linking — drop real keys into .env.local (never commit those)
# Plaid: https://dashboard.plaid.com
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# Stripe: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Encryption key for Plaid access tokens at rest (AES-256-GCM)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# Dashboard session auth — set real values in .env.local (never commit those)
# Generate password hash:
#   node -e "const {pbkdf2Sync,randomBytes}=require('crypto');const s=randomBytes(16);console.log(s.toString('hex')+':'+pbkdf2Sync('yourpassword',s,100000,32,'sha256').toString('hex'))"
DASHBOARD_ADMIN_EMAIL=
DASHBOARD_ADMIN_PASSWORD_HASH=

# Webhook security
# MAX_WEBHOOK_AMOUNT_CENTS: ceiling on any single webhook-triggered reward (default $5,000)
MAX_WEBHOOK_AMOUNT_CENTS=500000
# SQUARE_WEBHOOK_SIGNATURE_KEY: from Square Developer Dashboard → Webhooks → signature key
SQUARE_WEBHOOK_SIGNATURE_KEY=
