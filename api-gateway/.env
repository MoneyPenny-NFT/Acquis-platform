PORT=3000
HEDERA_NETWORK=testnet
DATABASE_URL=file:/tmp/acquis.db
REDIS_HOST=localhost
REDIS_PORT=6379

# Bank linking — drop real keys into .env.local (never commit those)
# Plaid: https://dashboard.plaid.com
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# Stripe: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Encryption key for Plaid access tokens at rest (AES-256-GCM)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=
