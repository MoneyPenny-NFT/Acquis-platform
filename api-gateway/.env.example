# Safe defaults — committed
PORT=3000
HEDERA_NETWORK=testnet
DATABASE_URL=file:/tmp/acquis.db
REDIS_HOST=localhost
REDIS_PORT=6379

# Secrets — copy to .env.local (gitignored, never committed)
HEDERA_OPERATOR_ID=0.0.XXXXXXX
HEDERA_OPERATOR_KEY=your_private_key_here
HEDERA_DEFAULT_TOKEN_ID=0.0.XXXXX
API_KEYS=your_api_key_here,optional_second_key_for_rotation

# Credential system (multi-chain identity) — safe defaults
CREDENTIAL_VERIFICATION_ENABLED=false
ACQUIS_NFT_TOKEN_ID=

# XRPL credential issuer — secrets (never committed)
XRPL_CREDENTIAL_ISSUER_ADDRESS=
XRPL_CREDENTIAL_ISSUER_SEED=

# KYC onboarding — keep false until attorney CIP documentation is complete
KYC_ENFORCEMENT_ENABLED=false
ONBOARDING_SERVICE_URL=http://localhost:3003

# Merchant onboarding / KYB — keep false until attorney review of the
# merchant services agreement text is complete
MERCHANT_AGREEMENT_ENABLED=false
# Stripe Connect Custom — keep false until STRIPE_SECRET_KEY (test-mode) is set
STRIPE_CONNECT_ENABLED=false

# QR-scan wallet enrollment (XRPL-first) — keep false until attorney review
# of the wallet-linkage consent text (services/enrollmentConsent.ts) is complete
QR_ENROLLMENT_ENABLED=false
# Xumm/Xaman SDK — service falls back to deterministic stubs when unset,
# which is useful for local dev without a real Xaman developer account
XUMM_API_KEY=
XUMM_API_SECRET=

# Merchant Rule Schema v1.1 enforcement engine — gates the pay.ts pre-check
# that validates every proposed transaction against the merchant's rule set.
# Adapter today is the stub; SmartNode/Hooks/native-contract can swap in
# later against the same @acquis/enforcement-engine validateTransaction()
# without touching the pay.ts integration or the rule schema.
ENFORCEMENT_ENGINE_ENABLED=false
