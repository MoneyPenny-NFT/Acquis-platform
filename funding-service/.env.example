# Server
PORT=3002
NODE_ENV=development

# API auth — comma-separated keys for inbound requests
API_KEYS=change-me-before-production

# Database (PostgreSQL in production; SQLite path for local dev)
DATABASE_URL=file:/tmp/funding-service.db

# Redis (required for Bull job queues)
REDIS_URL=redis://localhost:6379

# Hedera service base URL (internal service-to-service)
HEDERA_SERVICE_URL=http://localhost:3001
HEDERA_SERVICE_API_KEY=internal-change-me

# BankAdapter — set to "mock" for local dev; "crossriver" for production
BANK_ADAPTER=mock

# MockBankAdapter tuning (ms; only used when BANK_ADAPTER=mock)
MOCK_PRESENTED_DELAY_MS=500
MOCK_APPROVED_DELAY_MS=1000
MOCK_CREDIT_DELAY_MS=1500
# Scenario: happy | decline | expire | unmatched_credit
MOCK_SCENARIO=happy

# Reconciliation job schedule (cron)
EXPIRE_CRON=*/5 * * * *
SWEEP_CRON=*/10 * * * *
HCS_RETRY_CRON=*/2 * * * *
